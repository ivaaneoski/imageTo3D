# Python virtual environment and caches
venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Model Weights Cache (Hugging Face / ONNX models)
weights/
.cache/

# Local pipeline intermediates & test data
intermediates/

# Block large binary and image outputs
*.glb
*.gltf
*.bin
*.obj
*.mtl
*.ply
*.png
*.jpg
*.jpeg

# Allow test input images
!photo.jpg

# Ignore product spec
productSpec.md

# Allow test_data files
!test_data/
!test_data/*.glb
!test_data/*.ply
!test_data/*.jpg
!test_data/*.png
